    `url` VARCHAR(500) NOT NULL UNIQUE COMMENT '文章URL',
    `source_name` VARCHAR(100) NOT NULL COMMENT '来源名称',
    `title` VARCHAR(255) NOT NULL COMMENT '文章标题',
    `author` VARCHAR(100) NOT NULL COMMENT '作者',
    `tags` JSON COMMENT '标签JSON数组',
    `summary` LONGTEXT COMMENT '摘要',
    `content` LONGTEXT COMMENT '正文',
    `published_at` DATETIME(6) COMMENT '发布时间',
    `is_vector_synced` BOOL NOT NULL COMMENT '是否已同步到向量库',
    `vector_synced_at` DATETIME(6) COMMENT '向量库同步时间',
    `create_time` INT NOT NULL COMMENT '创建时间',
    `update_time` INT NOT NULL COMMENT '更新时间',
    `delete_time` INT NOT NULL COMMENT '删除时间',
    `operator` INT NOT NULL COMMENT '操作人ID',
    KEY `idx_tb_article__source__ae27cd` (`source_name`),
    KEY `idx_tb_article__publish_1ee5bf` (`published_at`),
    KEY `idx_tb_article__is_vect_0aaf2e` (`is_vector_synced`)
) CHARACTER SET utf8mb4 COMMENT='资讯文章模型';
