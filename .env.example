# 应用配置
APP_NAME="FastAPI Enterprise"
APP_VERSION="1.0.0"
DEBUG=true

# 服务配置
HOST=0.0.0.0
PORT=8000

# 数据库配置 (修改 URL 前缀即可切换数据库类型，无需改代码)
# MySQL:
DATABASE_URL=mysql://root:123456@127.0.0.1:3306/test
# PostgreSQL (将上面注释掉，取消以下注释即可切换):
# DATABASE_URL=postgresql://postgres:123456@127.0.0.1:5432/test

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置
JWT_SECRET="your-secret-key-change-in-production"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
 
# API Keys
OPENAI_API_KEY=

# Dify 知识库配置
# 登录 Dify 后台 → 知识库 → 目标知识库 → API 密钥
DIFY_API_KEY=your-dify-api-key
# 将 URL 中的 {dataset_id} 替换为你的知识库 ID
DIFY_API_URL=https://api.dify.ai/v1/datasets/YOUR_DATASET_ID/document/create_by_text
